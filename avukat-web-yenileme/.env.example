# Markdown dosyalari varsayilan blog kaynagidir.
# Harici bir CMS / API kullanmak isterseniz asagidaki ayarlari kullanabilirsiniz.

VITE_BLOG_API_URL=
VITE_BLOG_API_TOKEN=

# If your CMS response is nested, point to the post array.
# Example: data.items or entries.0.posts
VITE_BLOG_ITEMS_PATH=

# Override these only if the CMS field names differ from the local BlogPost shape.
VITE_BLOG_FIELD_SLUG=slug
VITE_BLOG_FIELD_TITLE=title
VITE_BLOG_FIELD_EXCERPT=excerpt
VITE_BLOG_FIELD_CONTENT=content
VITE_BLOG_FIELD_CATEGORY=category
VITE_BLOG_FIELD_AUTHOR=author
VITE_BLOG_FIELD_PUBLISHED_AT=publishedAt
VITE_BLOG_FIELD_UPDATED_AT=updatedAt
VITE_BLOG_FIELD_SEO_TITLE=seoTitle
VITE_BLOG_FIELD_SEO_DESCRIPTION=seoDescription
VITE_BLOG_FIELD_COVER_CLASS=coverClass
VITE_BLOG_FIELD_COVER_IMAGE=coverImage

# Public contact form endpoint for browser-side requests.
# On Vercel production, /api/contact can also be inferred automatically.
VITE_CONTACT_FORM_ENDPOINT=/api/contact
VITE_CONTACT_FORM_TOKEN=

# Vercel Function / Resend server-side secrets.
RESEND_API_KEY=
CONTACT_TO_EMAIL=
CONTACT_FROM_EMAIL=
CONTACT_ALLOWED_ORIGINS=https://vegahukukistanbul.com,https://www.vegahukukistanbul.com

# Decap CMS / GitHub OAuth secrets.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
