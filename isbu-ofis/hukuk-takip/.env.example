# ─── Veritabanı ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/hukuk_takip

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string-minimum-64-characters-long
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=another-long-random-string-for-refresh-tokens-64-chars
JWT_REFRESH_EXPIRES_IN=7d

# ─── Sunucu ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost:5173
AI_ACTIVE_CASES_ROOT=G:\Drive'im\Hukuk Burosu\Aktif Davalar
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_VERSION=2023-06-01
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# ─── Cookie ───────────────────────────────────────────────────────────────────
COOKIE_SECRET=yet-another-long-random-string-for-cookie-signing-64-chars

# ─── Dosya Yükleme ────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# ─── TC No Şifreleme (KVKK) ────────────────────────────────────────────────────
# openssl rand -hex 32  komutuyla oluşturun
ENCRYPTION_KEY=generate-with-openssl-rand-hex-32

# ─── E-posta (İsteğe bağlı - bildirimler için) ────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@hukuktakip.com
